HUBSPOT_TOKEN=
HUBSPOT_ACCOUNT_ID=5454671
AIRCALL_API_ID=
AIRCALL_API_TOKEN=
ANTHROPIC_API_KEY=
# Railway sets DATABASE_URL automatically via the PostgreSQL plugin.
# For local dev, use a local Postgres instance or Railway's dev URL:
DATABASE_URL=postgresql://user:password@localhost:5432/advisor_tool

# Google Calendar OAuth (optional — only needed to enable meeting countdown feature)
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI (add both in GCP console):
#   http://localhost:8000/api/auth/google/callback  (local dev)
#   https://<your-railway-url>/api/auth/google/callback  (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
